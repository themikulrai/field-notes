# Local single-process self-host (`field-notes serve`) needs NONE of this — it
# defaults to a file-backed SQLite under ~/.field-notes and disables auth on a
# loopback bind. The vars below are for the Postgres / networked dev stack
# (docker-compose, Heroku/Fly) only.

FIELD_NOTES_KEY=changeme
DATABASE_URL=postgresql+asyncpg://field_notes:field_notes@localhost:5432/field_notes
POSTGRES_USER=field_notes
POSTGRES_PASSWORD=field_notes
POSTGRES_DB=field_notes
